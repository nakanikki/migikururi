{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MigiKururi",
  "mainBinaryName": "MigiKururi",
  "version": "0.1.0",
  "identifier": "com.owner.piemenu",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "右くるり",
        "width": 600,
        "height": 600,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "shadow": false,
        "visible": false
      },
      {
        "label": "settings",
        "title": "右くるり",
        "url": "settings.html",
        "width": 1000,
        "height": 760,
        "resizable": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": [],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
